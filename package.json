{
  "name": "reka-solana",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/web"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "lint": "bun run --cwd apps/web lint",
    "preview": "bun run --cwd apps/web preview",
    "check:program": "node scripts/check-program.mjs",
    "contract:build": "cd contracts/reka && anchor build",
    "contract:deploy": "cd contracts/reka && anchor deploy --provider.cluster devnet"
  }
}
